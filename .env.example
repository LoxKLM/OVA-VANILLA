# Ova Vanilla — Variables d'environnement
# Renommer ce fichier en .env et renseigner les vraies valeurs
# NE JAMAIS committer le fichier .env dans Git

# ── EmailJS (compte AM Talents) ───────────────────────────────────────────
EMAILJS_PUBLIC_KEY=votre_cle_publique_emailjs
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_DEVIS=template_devis
EMAILJS_TEMPLATE_ECHANTILLON=template_echantillon

# ── Webhook GitHub → Hostinger ────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=remplacer_par_une_cle_secrete_longue_et_aleatoire

# ── Flask ─────────────────────────────────────────────────────────────────
FLASK_ENV=development
# En production sur Hostinger, mettre FLASK_ENV=production
PORT=5000
