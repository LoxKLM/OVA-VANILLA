# .htaccess — Ova Vanilla
# Apache / Hostinger shared hosting
# Ordre : HTTPS → URLs propres → sécurité → routage → cache → gzip

Options -Indexes -MultiViews
ServerSignature Off

# ── En-têtes de sécurité ─────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.emailjs.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.emailjs.com; frame-ancestors 'none';"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Réécriture d'URLs ─────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Forcer HTTPS — doit être en premier
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Fichiers à la racine — pass-through (pas de réécriture vers frontend/)
    RewriteRule ^webhook\.php$ - [L]
    RewriteRule ^robots\.txt$ - [L]
    RewriteRule ^sitemap\.xml$ - [L]
    RewriteRule ^\.well-known/ - [L]

    # 3. Bloquer l'accès aux fichiers internes sensibles
    RewriteRule ^(deploy|webhook)\.log$ - [F,L]
    RewriteRule ^deploy\.sh$ - [F,L]

    # 4. Supprimer l'extension .html — redirection 301 vers URL propre
    #    /contact.html   → /contact
    #    /nos-vanilles.html → /nos-vanilles
    RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
    RewriteRule ^ /%1 [R=301,L]

    # 5. Racine → frontend/index.html
    RewriteRule ^$ frontend/index.html [L]

    # 6. URL propre → frontend/page.html (si le fichier correspondant existe)
    #    /contact        → frontend/contact.html
    #    /en/index       → frontend/en/index.html
    RewriteCond %{DOCUMENT_ROOT}/frontend/$1.html -f
    RewriteRule ^([^.]+)$ frontend/$1.html [L]

    # 7. Fallback — assets et tout le reste → frontend/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)$ frontend/$1 [L]

</IfModule>

# ── Cache statique ────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html               "access plus 1 hour"
    ExpiresByType text/css                "access plus 1 month"
    ExpiresByType application/javascript  "access plus 1 month"
    ExpiresByType image/svg+xml           "access plus 1 month"
    ExpiresByType image/png               "access plus 6 months"
    ExpiresByType image/jpeg              "access plus 6 months"
    ExpiresByType image/webp              "access plus 6 months"
    ExpiresByType video/mp4               "access plus 6 months"
    ExpiresByType font/woff2              "access plus 1 year"
    ExpiresByType application/json        "access plus 1 hour"
</IfModule>

# ── Compression gzip ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
